# ═══════════════════════════════════════════════════════════════
# Heady™ Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# ── Critical (app won't start without these) ──
DATABASE_URL=
HEADY_API_KEY=

# ── Required (features degraded without these) ──
PERPLEXITY_API_KEY=
GEMINI_API_KEY=
GITHUB_TOKEN=
CLOUDFLARE_API_TOKEN=
SENTRY_DSN=

# ── Optional (graceful degradation) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_TOKEN=
STRIPE_SECRET_KEY=
NEON_DATABASE_URL=
PINECONE_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
HEADY_WEBHOOK_SECRET=
GCP_PROJECT_ID=
GCP_REGION=us-central1

# ── Server Config ──
PORT=3301
NODE_ENV=development
LOG_LEVEL=info
