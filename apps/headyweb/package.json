{
  "name": "headyweb",
  "version": "1.0.0-beta",
  "description": "HeadyWeb - Comet + Chromium Fusion Browser",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:chromium": "cross-env ENGINE=chromium vite build",
    "build:comet": "cross-env ENGINE=comet vite build",
    "build:fusion": "cross-env ENGINE=fusion vite build",
    "start": "electron .",
    "test": "jest",
    "test:engines": "jest --testPathPattern=engines",
    "test:ai": "jest --testPathPattern=ai",
    "test:quantum": "jest --testPathPattern=quantum",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "clean": "rimraf build dist"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.17.0",
    "axios": "^1.8.4",
    "electron": "^40.8.0",
    "framer-motion": "^11.3.28",
    "lucide-react": "^0.344.0",
    "onnxruntime-web": "^1.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.163.0",
    "webgl": "^0.0.7",
    "ws": "^8.18.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "electron-builder": "^26.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "postcss": "^8.5.2",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "browser",
    "comet",
    "chromium",
    "fusion",
    "quantum",
    "ai",
    "heady",
    "sacred-geometry"
  ],
  "author": "Heady Systems",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/headysystems/headyweb.git"
  }
}
