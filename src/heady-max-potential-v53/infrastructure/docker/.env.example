# ═══════════════════════════════════════════════════════════════════════════════
# Heady™ Environment Configuration
# © 2026 HeadySystems Inc. — Eric Haywood (eric@headysystems.com) — 51 Provisional Patents
# Copy to .env and fill in values. All numeric constants derive from φ or Fibonacci.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Core ────────────────────────────────────────────────────────────────────
# Platform-wide settings
NODE_ENV=production
HEADY_ENV=production
HEADY_VERSION=5.1.0

# ─── GCP / Cloud Run ────────────────────────────────────────────────────────
# Google Cloud project hosting the Heady platform
GCP_PROJECT=gen-lang-client-0920560496
GCP_REGION=us-east1
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-key.json

# ─── Firebase ────────────────────────────────────────────────────────────────
# Firebase for auth and real-time features
FIREBASE_PROJECT_ID=gen-lang-client-0920560496
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=gen-lang-client-0920560496.firebaseapp.com

# ─── Cloudflare ──────────────────────────────────────────────────────────────
# DNS and edge proxy configuration
CLOUDFLARE_ACCOUNT_ID=8b1fa38f282c691423c6399247d53323
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ─── Database (pgvector) ────────────────────────────────────────────────────
# PostgreSQL with pgvector extension for vector memory
PGVECTOR_PASSWORD=
PGVECTOR_URL=postgresql://heady:${PGVECTOR_PASSWORD}@pgvector:5432/heady
PGVECTOR_POOL_SIZE=34                   # fib(9) = 34 — connection pool size
PGVECTOR_MAX_CONNECTIONS=233            # fib(13) = 233 — max DB connections

# ─── Redis ───────────────────────────────────────────────────────────────────
# In-memory cache for session state and hot data
REDIS_URL=redis://redis:6379
REDIS_MAX_MEMORY=233mb                  # fib(13) = 233 — max memory in MB

# ─── NATS JetStream ─────────────────────────────────────────────────────────
# Event bus for inter-service messaging
NATS_URL=nats://nats:4222
NATS_MAX_PAYLOAD=1048576                # 1MB max message payload

# ─── Auth / Sessions ────────────────────────────────────────────────────────
# Session management and cookie configuration
SESSION_SECRET=
SESSION_TTL_MS=29034000                 # φ⁷ × 1000 × 1000 = ~29034s — session lifetime
COOKIE_DOMAIN=.headysystems.com

# ─── External AI APIs ───────────────────────────────────────────────────────
# API keys for concurrent model providers (all models operate as equals)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=
HUGGINGFACE_API_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Payment processing for budget-tracker service
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Discord ─────────────────────────────────────────────────────────────────
# Discord bot integration token
DISCORD_BOT_TOKEN=

# ─── Monitoring ──────────────────────────────────────────────────────────────
# Grafana and OpenTelemetry configuration
GRAFANA_PASSWORD=
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ─── Colab Pro+ (GPU Compute Layer) ─────────────────────────────────────────
# Google Colab runtimes for φ-pool GPU compute
COLAB_RUNTIME_HOT_URL=                  # Latency-sensitive inference pool
COLAB_RUNTIME_WARM_URL=                 # Background processing pool
COLAB_RUNTIME_COLD_URL=                 # Batch/analytics pool
COLAB_AUTH_TOKEN=

# ─── φ-Timing Constants (derived from phi-math.js) ──────────────────────────
# These are provided as reference; services import from shared/phi-math.js
# PHI_1_MS=1618                         # φ¹ × 1000 — quick retries
# PHI_2_MS=2618                         # φ² × 1000 — short operations
# PHI_3_MS=4236                         # φ³ × 1000 — standard timeout
# PHI_4_MS=6854                         # φ⁴ × 1000 — API call timeout
# PHI_5_MS=11090                        # φ⁵ × 1000 — complex operations
# PHI_7_MS=29034                        # φ⁷ × 1000 — heartbeat cycle

# ─── Fibonacci Resource Constants (reference) ───────────────────────────────
# FIB_4=3                               # Max retries per cycle
# FIB_5=5                               # Log max-file count
# FIB_7=13                              # Auto-success categories, log max-size MB
# FIB_11=89                             # Circuit breaker max connections
# FIB_12=144                            # Total auto-success tasks
# FIB_13=233                            # Default service memory limit (MB)
# FIB_15=610                            # Brain service memory limit (MB)
